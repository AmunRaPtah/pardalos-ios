{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "ios": {
        "image": "latest",
        "autoIncrement": true
      },
      "channel": "production"
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "latest"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "latest",
        "autoIncrement": true
      },
      "channel": "preview"
    }
  },
  "submit": {
    "production": {}
  }
}
